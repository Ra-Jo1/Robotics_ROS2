<?xml version="1.0" ?>
<sdf version="1.8">
  <model name="mecanum_robot">
    <pose>0 0 0.1 0 0 0</pose>

    <!-- Chassis -->
    <link name="base_link">
      <inertial>
        <mass>0.5</mass>
        <inertia>
          <ixx>0.02</ixx><iyy>0.02</iyy><izz>0.04</izz>
        </inertia>
      </inertial>
      <visual name="base_visual">
        <geometry>
          <box><size>0.18 0.14 0.09</size></box>
        </geometry>
        <material>
          <ambient>0.9 0.9 0.9 1</ambient>
          <diffuse>0.9 0.9 0.9 1</diffuse>
        </material>
      </visual>
      <collision name="base_collision">
        <geometry>
          <box><size>0.30 0.25 0.07</size></box>
        </geometry>
      </collision>
    </link>

    <!-- Roue Avant Gauche -->
    <link name="wheel_fl">
      <pose>0.10 0.14 0 1.5707 0 0</pose>
      <inertial><mass>0.05</mass>
        <inertia><ixx>0.001</ixx><iyy>0.001</iyy><izz>0.001</izz></inertia>
      </inertial>
      <visual name="vis">
        <geometry><cylinder><radius>0.025</radius><length>0.02</length></cylinder></geometry>
        <material><ambient>0.1 0.1 0.1 1</ambient><diffuse>0.1 0.1 0.1 1</diffuse></material>
      </visual>
      <collision name="col">
        <geometry><cylinder><radius>0.025</radius><length>0.02</length></cylinder></geometry>
      </collision>
    </link>
    <joint name="joint_fl" type="revolute">
      <parent>base_link</parent><child>wheel_fl</child>
      <axis><xyz>0 0 1</xyz></axis>
    </joint>

    <!-- Roue Avant Droite -->
    <link name="wheel_fr">
      <pose>0.10 -0.14 0 1.5707 0 0</pose>
      <inertial><mass>0.05</mass>
        <inertia><ixx>0.001</ixx><iyy>0.001</iyy><izz>0.001</izz></inertia>
      </inertial>
      <visual name="vis">
        <geometry><cylinder><radius>0.025</radius><length>0.02</length></cylinder></geometry>
        <material><ambient>0.1 0.1 0.1 1</ambient><diffuse>0.1 0.1 0.1 1</diffuse></material>
      </visual>
      <collision name="col">
        <geometry><cylinder><radius>0.025</radius><length>0.02</length></cylinder></geometry>
      </collision>
    </link>
    <joint name="joint_fr" type="revolute">
      <parent>base_link</parent><child>wheel_fr</child>
      <axis><xyz>0 0 1</xyz></axis>
    </joint>

    <!-- Roue Arrière Gauche -->
    <link name="wheel_rl">
      <pose>-0.10 0.14 0 1.5707 0 0</pose>
      <inertial><mass>0.05</mass>
        <inertia><ixx>0.001</ixx><iyy>0.001</iyy><izz>0.001</izz></inertia>
      </inertial>
      <visual name="vis">
        <geometry><cylinder><radius>0.025</radius><length>0.02</length></cylinder></geometry>
        <material><ambient>0.1 0.1 0.1 1</ambient><diffuse>0.1 0.1 0.1 1</diffuse></material>
      </visual>
      <collision name="col">
        <geometry><cylinder><radius>0.025</radius><length>0.02</length></cylinder></geometry>
      </collision>
    </link>
    <joint name="joint_rl" type="revolute">
      <parent>base_link</parent><child>wheel_rl</child>
      <axis><xyz>0 0 1</xyz></axis>
    </joint>

    <!-- Roue Arrière Droite -->
    <link name="wheel_rr">
      <pose>-0.10 -0.14 0 1.5707 0 0</pose>
      <inertial><mass>0.05</mass>
        <inertia><ixx>0.001</ixx><iyy>0.001</iyy><izz>0.001</izz></inertia>
      </inertial>
      <visual name="vis">
        <geometry><cylinder><radius>0.025</radius><length>0.02</length></cylinder></geometry>
        <material><ambient>0.1 0.1 0.1 1</ambient><diffuse>0.1 0.1 0.1 1</diffuse></material>
      </visual>
      <collision name="col">
        <geometry><cylinder><radius>0.025</radius><length>0.02</length></cylinder></geometry>
      </collision>
    </link>
    <joint name="joint_rr" type="revolute">
      <parent>base_link</parent><child>wheel_rr</child>
      <axis><xyz>0 0 1</xyz></axis>
    </joint>

    <!-- Plugin Mecanum -->
    <plugin filename="gz-sim-mecanum-drive-system"
            name="gz::sim::systems::MecanumDrive">
      <front_left_joint>joint_fl</front_left_joint>
      <front_right_joint>joint_fr</front_right_joint>
      <back_left_joint>joint_rl</back_left_joint>
      <back_right_joint>joint_rr</back_right_joint>
      <wheel_separation>0.28</wheel_separation>
      <wheelbase>0.20</wheelbase>
      <wheel_radius>0.05</wheel_radius>
      <topic>cmd_vel</topic>
      <odom_topic>odom</odom_topic>
    </plugin>

    <!-- Plugin odométrie -->
    <plugin filename="gz-sim-odometry-publisher-system"
            name="gz::sim::systems::OdometryPublisher">
      <odom_frame>odom</odom_frame>
      <robot_base_frame>base_link</robot_base_frame>
    </plugin>

  </model>
</sdf>
